# Use official Red Hat JBoss EAP 7.4 image
FROM registry.redhat.io/jboss-eap-7/eap74-openjdk11-openshift-rhel8:latest

# Copy the WAR file to the deployments directory
# JBoss EAP automatically deploys WARs found in /deployments
COPY --chown=jboss:jboss target/kitchensink.war /deployments/ROOT.war

# Expose HTTP port
EXPOSE 8080

# Expose management port for health checks
EXPOSE 9990

# Run as jboss user (non-root)
USER jboss

# JBoss EAP will start automatically via the base image's CMD
