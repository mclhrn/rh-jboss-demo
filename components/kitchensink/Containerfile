# Use public WildFly image (compatible with JBoss EAP)
FROM quay.io/wildfly/wildfly:27.0.1.Final-jdk11

# Copy the WAR file to the deployments directory
# WildFly automatically deploys WARs found in /opt/jboss/wildfly/standalone/deployments
COPY --chown=jboss:root target/kitchensink.war /opt/jboss/wildfly/standalone/deployments/ROOT.war

# Expose HTTP port
EXPOSE 8080

# Expose management port for health checks
EXPOSE 9990

# Run as jboss user (non-root)
USER jboss

# WildFly will start automatically via the base image's CMD
